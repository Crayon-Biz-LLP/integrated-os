#!/bin/bash
# Pre-push hook: export codebase to Notebook LM sources and sync to Google Drive.
set -euo pipefail

REPO_ROOT="$(cd "$(dirname "$0")/../.." && pwd)"
SCRIPT="$REPO_ROOT/scripts/export-to-notebooklm.sh"

if [ -x "$SCRIPT" ]; then
    echo ""
    echo "=== Notebook LM Export ==="
    echo "Exporting codebase to Google Drive for Notebook LM..."
    "$SCRIPT"
    echo ""
fi
